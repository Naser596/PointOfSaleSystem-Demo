@model WebApplication3.Models.PaymentSuccessViewModel
@{
    ViewData["Title"] = "Payment Successful";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card text-center">
            <div class="card-body py-5">
                <div class="mb-4">
                    <div class="success-icon-wrapper">
                        <i class="fas fa-check-circle fa-5x text-success"></i>
                    </div>
                </div>
                
                <h2 class="mb-3">Payment Successful!</h2>
                <p class="text-muted mb-4">Your order has been processed successfully.</p>
                
                <div class="bg-light rounded-3 p-4 mb-4">
                    <div class="row text-start">
                        <div class="col-6 mb-3">
                            <small class="text-muted text-uppercase">Sale Number</small>
                            <div class="fw-bold fs-5">@Model.SaleNumber</div>
                        </div>
                        <div class="col-6 mb-3">
                            <small class="text-muted text-uppercase">Amount Paid</small>
                            <div class="fw-bold fs-5 text-success">$@Model.TotalAmount.ToString("N2")</div>
                        </div>
                        <div class="col-6">
                            <small class="text-muted text-uppercase">Payment Method</small>
                            <div class="fw-bold">
                                @if (Model.PaymentMethod == "DebitCard")
                                {
                                    <i class="fas fa-credit-card me-1 text-primary"></i>
                                    <span>Debit Card</span>
                                }
                                else
                                {
                                    <i class="fas fa-money-bill-wave me-1 text-success"></i>
                                    <span>Cash</span>
                                }
                            </div>
                        </div>
                        <div class="col-6">
                            <small class="text-muted text-uppercase">Date</small>
                            <div class="fw-bold">@Model.SaleDate.ToString("MMM dd, yyyy HH:mm")</div>
                        </div>
                    </div>
                </div>
                
                <div class="d-flex gap-3 justify-content-center">
                    <a href="/POS" class="btn btn-success">
                        <i class="fas fa-plus me-2"></i>New Sale
                    </a>
                    <a href="/Sales" class="btn btn-outline-primary">
                        <i class="fas fa-receipt me-2"></i>View Sales
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<style>
    .success-icon-wrapper {
        animation: scaleIn 0.5s ease-out;
    }
    
    @@keyframes scaleIn {
        0% {
            transform: scale(0);
            opacity: 0;
        }
        50% {
            transform: scale(1.2);
        }
        100% {
            transform: scale(1);
            opacity: 1;
        }
    }
</style>
}
