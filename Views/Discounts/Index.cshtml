@model IEnumerable<WebApplication3.Models.Discount>

@{
    ViewData["Title"] = "Discounts";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1><i class="fas fa-tags me-2"></i>Discounts</h1>
    <a asp-action="Create" class="btn btn-success">
        <i class="fas fa-plus me-1"></i>New Discount
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Type</th>
                        <th>Value</th>
                        <th>Valid To</th>
                        <th>Status</th>
                        <th>Used</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="@(!item.IsActive ? "text-muted bg-light" : "")">
                            <td><span class="fw-bold font-monospace">@item.Code</span></td>
                            <td>@item.Name</td>
                            <td>@item.DiscountType</td>
                            <td>
                                @if (item.DiscountType == WebApplication3.Models.DiscountType.Percentage)
                                {
                                    <span class="text-primary fw-bold">@item.Value.ToString("0")%</span>
                                }
                                else
                                {
                                    <span class="text-success fw-bold">$@item.Value.ToString("N2")</span>
                                }
                            </td>
                            <td>@(item.EndDate?.ToString("MMM dd, yyyy") ?? "-")</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>@item.UsedCount @(item.UsageLimit.HasValue ? $"/ {item.UsageLimit}" : "")</td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"
                                    title="Edit">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger"
                                    onclick="deleteDiscount(@item.Id, '@item.Code')">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="fas fa-tag fa-3x mb-3"></i>
                    <p>No discounts found.</p>
                </div>
            }
        </div>
    </div>
</div>

<form id="deleteForm" asp-action="Delete" method="post" style="display:none;">
    <input type="hidden" id="deleteId" name="id" />
</form>

@section Scripts {
    <script>
        function deleteDiscount(id, code) {
            Swal.fire({
                title: 'Delete Discount?',
                text: `Are you sure you want to delete "${code}"?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('deleteId').value = id;
                    document.getElementById('deleteForm').submit();
                }
            })
        }
    </script>
}
