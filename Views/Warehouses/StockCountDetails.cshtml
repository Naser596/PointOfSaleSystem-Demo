@model StockCount
@{
    ViewData["Title"] = "Stock Count";
}

<div class="page-header d-flex justify-content-between align-items-start gap-3">
    <div>
        <h1><i class="fas fa-clipboard-check me-3"></i>@Model.CountNumber</h1>
        <p>@Model.Warehouse.Name - @Model.CountDate.ToString("MMM dd, yyyy")</p>
    </div>
    <div class="d-flex gap-2">
        @if (Model.Status != "Posted")
        {
            <form asp-action="PostStockCount" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-success" onclick="return confirm('Post this count and create variance adjustments?')">
                    <i class="fas fa-check me-2"></i>Post Count
                </button>
            </form>
        }
        <a href="/Warehouses/StockCounts" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="card">
    <div class="card-header"><i class="fas fa-list me-2"></i>Count Lines</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Location</th>
                        <th class="text-end">System</th>
                        <th class="text-end">Counted</th>
                        <th class="text-end">Variance</th>
                        <th>Reason</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var line in Model.Lines.OrderBy(l => l.Product.Name))
                {
                    <tr>
                        <td><strong>@line.Product.Name</strong><div class="small text-muted">@line.Product.SKU</div></td>
                        <td>@(line.StockLocation?.Name ?? "-")</td>
                        <td class="text-end">@line.SystemQuantity.ToString("N2")</td>
                        <form asp-action="UpdateStockCountLine" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="StockCountId" value="@Model.Id" />
                            <input type="hidden" name="LineId" value="@line.Id" />
                            <td class="text-end" style="max-width: 130px;">
                                <input name="CountedQuantity" type="number" min="0" step="0.001" value="@((line.CountedQuantity ?? line.SystemQuantity).ToString("0.###"))" class="form-control form-control-sm text-end" @(Model.Status == "Posted" ? "disabled" : "") />
                            </td>
                            <td class="text-end fw-bold @(line.Variance == 0 ? "text-success" : "text-warning")">@line.Variance.ToString("N2")</td>
                            <td style="min-width: 180px;">
                                <input name="Reason" value="@line.Reason" class="form-control form-control-sm" @(Model.Status == "Posted" ? "disabled" : "") />
                            </td>
                            <td class="text-end">
                                @if (Model.Status != "Posted")
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-primary">Save</button>
                                }
                                else
                                {
                                    <span class="text-muted">Posted</span>
                                }
                            </td>
                        </form>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
