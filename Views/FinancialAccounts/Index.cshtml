@model FinancialAccountsDashboardViewModel
@{
    ViewData["Title"] = "Financial Accounts";
    var accountTypes = new[] { "Cash", "Bank", "CardClearing", "Loan", "Other" };
    var transactionTypes = new[] { "Debit", "Credit" };
}

<div class="page-header d-flex justify-content-between align-items-start gap-3">
    <div>
        <h1><i class="fas fa-building-columns me-3"></i>Cash & Bank</h1>
        <p>Financial accounts, bank movements, and payment records prepared for reconciliation.</p>
    </div>
    <a href="/Erp" class="btn btn-outline-secondary"><i class="fas fa-sitemap me-2"></i>ERP Core</a>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header"><i class="fas fa-plus me-2"></i>New Financial Account</div>
            <div class="card-body">
                <form asp-action="CreateAccount" method="post" class="row g-3">
                    @Html.AntiForgeryToken()
                    <div class="col-md-7">
                        <label class="form-label">Name</label>
                        <input name="Name" class="form-control" required />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Type</label>
                        <select name="AccountType" class="form-select">
                            @foreach (var type in accountTypes)
                            {
                                <option value="@type">@type</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Account No.</label>
                        <input name="AccountNumber" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Currency</label>
                        <input name="CurrencyCode" class="form-control" value="USD" maxlength="10" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Opening</label>
                        <input name="OpeningBalance" type="number" step="0.01" class="form-control" value="0" />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-success w-100"><i class="fas fa-plus me-2"></i>Create Account</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header"><i class="fas fa-money-bill-transfer me-2"></i>New Bank Transaction</div>
            <div class="card-body">
                <form asp-action="CreateTransaction" method="post" class="row g-3">
                    @Html.AntiForgeryToken()
                    <div class="col-md-4">
                        <label class="form-label">Account</label>
                        <select name="FinancialAccountId" class="form-select" required>
                            <option value="">Select</option>
                            @foreach (var account in Model.Accounts)
                            {
                                <option value="@account.Id">@account.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Type</label>
                        <select name="TransactionType" class="form-select">
                            @foreach (var type in transactionTypes)
                            {
                                <option value="@type">@type</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Date</label>
                        <input name="TransactionDate" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Amount</label>
                        <input name="Amount" type="number" step="0.01" min="0.01" class="form-control" required />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Reference</label>
                        <input name="Reference" class="form-control" />
                    </div>
                    <div class="col-md-9">
                        <label class="form-label">Description</label>
                        <input name="Description" class="form-control" />
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button type="submit" class="btn btn-success w-100"><i class="fas fa-plus me-2"></i>Add</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header"><i class="fas fa-building-columns me-2"></i>Accounts</div>
            <div class="card-body p-0">
                @if (Model.Accounts.Any())
                {
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Type</th>
                                <th class="text-end">Opening</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var account in Model.Accounts)
                            {
                                <tr>
                                    <td><strong>@account.Name</strong><div class="small text-muted">@account.CurrencyCode @account.AccountNumber</div></td>
                                    <td>@account.AccountType</td>
                                    <td class="text-end">$@account.OpeningBalance.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-building-columns fa-3x mb-3"></i>
                        <p>No financial accounts yet.</p>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header"><i class="fas fa-money-bill-transfer me-2"></i>Recent Bank Transactions</div>
            <div class="card-body p-0">
                @if (Model.BankTransactions.Any())
                {
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Account</th>
                                <th>Reference</th>
                                <th>Status</th>
                                <th class="text-end">Amount</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var transaction in Model.BankTransactions)
                            {
                                <tr>
                                    <td>@transaction.TransactionDate.ToString("MMM dd, yyyy")</td>
                                    <td>@transaction.FinancialAccount.Name</td>
                                    <td><strong>@(transaction.Reference ?? "-")</strong><div class="small text-muted">@transaction.Description</div></td>
                                    <td><span class="badge bg-secondary">@transaction.Status</span></td>
                                    <td class="text-end">@transaction.TransactionType $@transaction.Amount.ToString("N2")</td>
                                    <td class="text-end">
                                        @if (transaction.Status != "Reconciled")
                                        {
                                            <form asp-action="MarkReconciled" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@transaction.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-success">Reconcile</button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-money-bill-transfer fa-3x mb-3"></i>
                        <p>No bank transactions yet.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
