@model PurchasingDashboardViewModel
@{
    ViewData["Title"] = "Purchasing";
    var statuses = new[] { "Draft", "Sent", "PendingApproval", "PartiallyReceived", "Received", "Cancelled" };
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-truck-ramp-box me-3"></i>Purchasing</h1>
        <p>Purchase order foundation for suppliers, expected deliveries, and cost control.</p>
    </div>
    <div class="page-actions">
        <a href="/Erp" class="btn btn-outline-secondary"><i class="fas fa-sitemap me-2"></i>ERP Core</a>
    </div>
</div>

@if (Model.LowStockProducts.Any())
{
    <div class="data-table-card mb-4">
        <div class="erp-surface-header">
            <div>
                <h2 class="erp-surface-title"><i class="fas fa-cart-plus me-2"></i>Reorder Suggestions</h2>
                <p class="erp-surface-subtitle">Low-stock products that can be converted directly into purchase orders.</p>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead><tr><th>Product</th><th class="text-end">Stock</th><th class="text-end">Min</th><th class="text-end">Suggest</th><th class="text-end">Action</th></tr></thead>
                <tbody>
                @foreach (var product in Model.LowStockProducts)
                {
                    var targetStock = Math.Max(product.MinStock * 2, product.MinStock + 1);
                    var suggestedQuantity = Math.Max(targetStock - product.Stock, 1);
                    <tr>
                        <td><strong>@product.Name</strong><div class="small text-muted">@product.SKU</div></td>
                        <td class="text-end"><span class="badge bg-warning text-dark">@product.Stock</span></td>
                        <td class="text-end">@product.MinStock</td>
                        <td class="text-end fw-bold">@suggestedQuantity</td>
                        <td class="text-end">
                            <form asp-action="CreateFromReorder" method="post" class="d-flex justify-content-end gap-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ProductId" value="@product.Id" />
                                <input type="hidden" name="SuggestedQuantity" value="@suggestedQuantity" />
                                <input name="SupplierName" class="form-control form-control-sm" placeholder="Supplier" style="max-width: 180px;" required />
                                <button type="submit" class="btn btn-sm btn-outline-primary">Create PO</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="inline-action-card">
    <div class="erp-surface-header">
        <div>
            <h2 class="erp-surface-title"><i class="fas fa-plus me-2"></i>New Purchase Order</h2>
            <p class="erp-surface-subtitle">Create a supplier order header before adding product lines.</p>
        </div>
    </div>
    <div class="form-section">
        <form asp-action="Create" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <div class="col-md-2">
                <label class="form-label">Order No.</label>
                <input name="OrderNumber" class="form-control" placeholder="Auto" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Supplier</label>
                <input name="SupplierName" class="form-control" required />
            </div>
            <div class="col-md-2">
                <label class="form-label">Tax No.</label>
                <input name="SupplierTaxNumber" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Order Date</label>
                <input name="OrderDate" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Expected</label>
                <input name="ExpectedDate" type="date" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select name="Status" class="form-select">
                    @foreach (var status in statuses)
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Subtotal</label>
                <input name="SubTotal" type="number" step="0.01" min="0" class="form-control" value="0" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Tax</label>
                <input name="TaxAmount" type="number" step="0.01" min="0" class="form-control" value="0" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Notes</label>
                <input name="Notes" class="form-control" placeholder="Optional note" />
            </div>
            <div class="col-12 d-flex justify-content-end">
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-plus me-2"></i>Create Purchase Order
                </button>
            </div>
        </form>
    </div>
</div>

<div class="data-table-card">
    <div class="erp-surface-header">
        <div>
            <h2 class="erp-surface-title"><i class="fas fa-list me-2"></i>Purchase Orders</h2>
            <p class="erp-surface-subtitle">Supplier, expected date, receipt state, and total value.</p>
        </div>
    </div>
    @if (Model.PurchaseOrders.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Order</th>
                        <th>Supplier</th>
                        <th>Order Date</th>
                        <th>Expected</th>
                        <th>Lines</th>
                        <th>Status</th>
                        <th class="money-cell">Total</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.PurchaseOrders)
                    {
                        <tr>
                            <td><strong>@order.OrderNumber</strong></td>
                            <td>@order.SupplierName</td>
                            <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                            <td>@(order.ExpectedDate?.ToString("MMM dd, yyyy") ?? "-")</td>
                            <td>@order.Lines.Count</td>
                            <td><span class="status-pill">@order.Status</span></td>
                            <td class="money-cell">$@order.TotalAmount.ToString("N2")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-eye me-1"></i>View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="state-card">
            <i class="fas fa-truck-ramp-box fa-3x mb-3"></i>
            <p>No purchase orders yet.</p>
        </div>
    }
</div>
