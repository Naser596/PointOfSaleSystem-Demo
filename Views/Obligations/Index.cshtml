@model CompanyObligationsViewModel
@{
    ViewData["Title"] = "Company Obligations";
    var types = new[] { "Payroll", "Debt", "Advance", "Unpaid Invoice", "Rent", "Tax", "Utilities", "Other" };
    var statuses = new[] { "Open", "Paid", "All" };
}

<div class="page-header d-flex justify-content-between align-items-start gap-3">
    <div>
        <h1><i class="fas fa-hand-holding-dollar me-3"></i>Company Obligations</h1>
        <p>Track salaries, debts, advances, unpaid invoices, rent, tax, and other payments the company must make.</p>
    </div>
    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addObligationModal">
        <i class="fas fa-plus me-2"></i>Add Obligation
    </button>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="stat-card warning">
            <i class="fas fa-clock stat-icon"></i>
            <div class="stat-value">$@Model.OpenTotal.ToString("N2")</div>
            <div class="stat-label">Open Obligations</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="stat-card danger">
            <i class="fas fa-triangle-exclamation stat-icon"></i>
            <div class="stat-value">$@Model.OverdueTotal.ToString("N2")</div>
            <div class="stat-label">Overdue</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="stat-card primary">
            <i class="fas fa-calendar-day stat-icon"></i>
            <div class="stat-value">$@Model.DueThisMonthTotal.ToString("N2")</div>
            <div class="stat-label">Due This Month</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="stat-card success">
            <i class="fas fa-check stat-icon"></i>
            <div class="stat-value">$@Model.PaidThisMonthTotal.ToString("N2")</div>
            <div class="stat-label">Paid This Month</div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Status</label>
                <select name="status" class="form-select">
                    @foreach (var status in statuses)
                    {
                        <option value="@status" selected="@(string.Equals(Model.Status, status, StringComparison.OrdinalIgnoreCase))">@status</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Type</label>
                <select name="type" class="form-select">
                    <option value="All" selected="@(string.IsNullOrWhiteSpace(Model.Type) || Model.Type == "All")">All</option>
                    @foreach (var type in types)
                    {
                        <option value="@type" selected="@(string.Equals(Model.Type, type, StringComparison.OrdinalIgnoreCase))">@type</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-filter me-2"></i>Apply Filters
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <i class="fas fa-list me-2"></i>Obligations
    </div>
    <div class="card-body p-0">
        @if (Model.Obligations.Any())
        {
            <div class="table-responsive">
                <table class="table mb-0 obligation-table">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>Description</th>
                            <th>Payee / Person</th>
                            <th class="text-end">Amount</th>
                            <th>Due Date</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Obligations)
                        {
                            var rowClass = item.IsOverdue ? "table-danger obligation-overdue" : !item.IsPaid ? "obligation-open" : "";
                            <tr class="@rowClass">
                                <td><span class="badge bg-secondary">@item.ObligationType</span></td>
                                <td>
                                    <strong>@item.Description</strong>
                                    @if (!string.IsNullOrWhiteSpace(item.Notes))
                                    {
                                        <div class="small text-muted">@item.Notes</div>
                                    }
                                </td>
                                <td>@(item.PayeeName ?? "-")</td>
                                <td class="text-end fw-bold">$@item.Amount.ToString("N2")</td>
                                <td>
                                    @if (item.DueDate.HasValue)
                                    {
                                        <span>@item.DueDate.Value.ToString("MMM dd, yyyy")</span>
                                        @if (item.IsOverdue)
                                        {
                                            <div class="small text-danger fw-bold">Overdue</div>
                                        }
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge @(item.IsPaid ? "bg-success" : item.IsOverdue ? "bg-danger" : "bg-warning text-dark")">
                                        @(item.IsPaid ? "Paid" : item.IsOverdue ? "Overdue" : item.Status)
                                    </span>
                                </td>
                                <td class="text-end">
                                    @if (!item.IsPaid)
                                    {
                                        <form asp-action="MarkPaid" method="post" class="d-inline-flex gap-1 justify-content-end flex-wrap">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="Id" value="@item.Id" />
                                            <input type="hidden" name="PaymentDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                                            <input type="hidden" name="PaymentMethod" value="Cash" />
                                            <select name="FinancialAccountId" class="form-select form-select-sm obligation-account-select">
                                                <option value="">Cash / no account</option>
                                                @foreach (var account in Model.FinancialAccounts)
                                                {
                                                    <option value="@account.Id">@account.Name</option>
                                                }
                                            </select>
                                            <button type="submit" class="btn btn-sm btn-outline-success">Pay & Post</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="MarkOpen" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-warning">Reopen</button>
                                        </form>
                                    }
                                    <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this obligation?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-check-circle fa-3x mb-3"></i>
                <p>No obligations found for this filter.</p>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="addObligationModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-plus-circle me-2"></i>Add Company Obligation</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Type</label>
                            <select asp-for="Input.ObligationType" name="ObligationType" class="form-select">
                                @foreach (var type in types)
                                {
                                    <option value="@type">@type</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Payee / Person</label>
                            <input asp-for="Input.PayeeName" name="PayeeName" class="form-control" placeholder="Employee, supplier, landlord..." />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <input asp-for="Input.Description" name="Description" class="form-control" placeholder="Salary for May, advance to employee, unpaid invoice..." />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Due Date</label>
                            <input asp-for="Input.DueDate" name="DueDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Amount</label>
                            <input asp-for="Input.Amount" name="Amount" type="number" min="0" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Status</label>
                            <select asp-for="Input.Status" name="Status" class="form-select">
                                <option value="Open">Open</option>
                                <option value="Paid">Paid</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Notes</label>
                            <textarea asp-for="Input.Notes" name="Notes" class="form-control" rows="3" placeholder="Example: gave advance, remaining salary, supplier invoice number..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save me-2"></i>Save Obligation
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
