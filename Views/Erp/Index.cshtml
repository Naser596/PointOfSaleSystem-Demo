@model ErpDashboardViewModel
@{
    ViewData["Title"] = "ERP Core";
}

<div class="page-header d-flex justify-content-between align-items-start gap-3">
    <div>
        <h1><i class="fas fa-sitemap me-3"></i>ERP Core</h1>
        <p>Accounting, approvals, sales documents, purchasing, warehouse, and banking foundation.</p>
    </div>
    <a href="/Accounting" class="btn btn-primary">
        <i class="fas fa-scale-balanced me-2"></i>Accounting
    </a>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="stat-card primary">
            <i class="fas fa-list-ol stat-icon"></i>
            <div class="stat-value">@Model.AccountCount</div>
            <div class="stat-label">Accounts</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="stat-card success">
            <i class="fas fa-book stat-icon"></i>
            <div class="stat-value">@Model.JournalEntryCount</div>
            <div class="stat-label">Journal Entries</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="stat-card warning">
            <i class="fas fa-file-invoice stat-icon"></i>
            <div class="stat-value">@Model.SalesDocumentCount</div>
            <div class="stat-label">Sales Documents</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="stat-card info">
            <i class="fas fa-truck-ramp-box stat-icon"></i>
            <div class="stat-value">@Model.PurchaseOrderCount</div>
            <div class="stat-label">Purchase Orders</div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="stat-card secondary">
            <i class="fas fa-warehouse stat-icon"></i>
            <div class="stat-value">@Model.WarehouseCount</div>
            <div class="stat-label">Warehouses</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="stat-card primary">
            <i class="fas fa-building-columns stat-icon"></i>
            <div class="stat-value">@Model.FinancialAccountCount</div>
            <div class="stat-label">Cash / Bank Accounts</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="stat-card warning">
            <i class="fas fa-user-check stat-icon"></i>
            <div class="stat-value">@Model.PendingApprovalCount</div>
            <div class="stat-label">Pending Approvals</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="stat-card success">
            <i class="fas fa-paperclip stat-icon"></i>
            <div class="stat-value">@Model.AttachmentCount</div>
            <div class="stat-label">Documents</div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <i class="fas fa-bell me-2"></i>ERP Alerts
    </div>
    <div class="card-body p-0">
        @if (Model.Alerts.Any())
        {
            <div class="list-group list-group-flush">
                @foreach (var alert in Model.Alerts)
                {
                    var badgeClass = alert.Severity == "Danger" ? "bg-danger" : alert.Severity == "Warning" ? "bg-warning text-dark" : "bg-info";
                    <a href="@alert.Url" class="list-group-item list-group-item-action d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">
                                <i class="fas @alert.Icon me-2"></i>@alert.Title
                            </div>
                            <div class="small text-muted">@alert.Message</div>
                        </div>
                        <div class="text-end">
                            <span class="badge @badgeClass">@alert.Severity</span>
                            @if (alert.DueDate.HasValue)
                            {
                                <div class="small text-muted mt-1">@alert.DueDate.Value.ToString("MMM dd, yyyy")</div>
                            }
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-bell fa-3x mb-3"></i>
                <p>No ERP alerts right now.</p>
            </div>
        }
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <i class="fas fa-layer-group me-2"></i>ERP Work Areas
    </div>
    <div class="list-group list-group-flush">
        <a href="/Accounting" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <span><i class="fas fa-scale-balanced me-2 text-primary"></i>Accounting setup</span>
            <i class="fas fa-chevron-right text-muted"></i>
        </a>
        <a href="/SalesDocuments" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <span><i class="fas fa-file-invoice me-2 text-primary"></i>Sales documents</span>
            <i class="fas fa-chevron-right text-muted"></i>
        </a>
        <a href="/Purchasing" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <span><i class="fas fa-truck-ramp-box me-2 text-primary"></i>Purchasing</span>
            <i class="fas fa-chevron-right text-muted"></i>
        </a>
        <a href="/Warehouses" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <span><i class="fas fa-warehouse me-2 text-primary"></i>Warehouses</span>
            <i class="fas fa-chevron-right text-muted"></i>
        </a>
        <a href="/FinancialAccounts" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <span><i class="fas fa-building-columns me-2 text-primary"></i>Cash and bank</span>
            <i class="fas fa-chevron-right text-muted"></i>
        </a>
        <a href="/Hr" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <span><i class="fas fa-users-gear me-2 text-primary"></i>HR and payroll</span>
            <i class="fas fa-chevron-right text-muted"></i>
        </a>
        <a href="/Reports" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <span><i class="fas fa-chart-line me-2 text-primary"></i>Reports and analytics</span>
            <i class="fas fa-chevron-right text-muted"></i>
        </a>
        <a href="/Approvals" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <span><i class="fas fa-user-check me-2 text-primary"></i>Approvals</span>
            <i class="fas fa-chevron-right text-muted"></i>
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">
                <i class="fas fa-book me-2"></i>Recent Journal Entries
            </div>
            <div class="card-body p-0">
                @if (Model.RecentJournalEntries.Any())
                {
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Entry</th>
                                <th>Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in Model.RecentJournalEntries)
                            {
                                <tr>
                                    <td><strong>@entry.EntryNumber</strong><div class="small text-muted">@entry.Description</div></td>
                                    <td>@entry.EntryDate.ToString("MMM dd, yyyy")</td>
                                    <td><span class="badge bg-secondary">@entry.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-book fa-3x mb-3"></i>
                        <p>No journal entries yet.</p>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">
                <i class="fas fa-truck-ramp-box me-2"></i>Recent Purchase Orders
            </div>
            <div class="card-body p-0">
                @if (Model.RecentPurchaseOrders.Any())
                {
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Order</th>
                                <th>Supplier</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.RecentPurchaseOrders)
                            {
                                <tr>
                                    <td><strong>@order.OrderNumber</strong><div class="small text-muted">@order.Status</div></td>
                                    <td>@order.SupplierName</td>
                                    <td class="text-end">$@order.TotalAmount.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-truck-ramp-box fa-3x mb-3"></i>
                        <p>No purchase orders yet.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
