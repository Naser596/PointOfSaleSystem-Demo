@model IEnumerable<WebApplication3.Models.Customer>

@{
    ViewData["Title"] = "Customers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1><i class="fas fa-users me-2"></i>Customers</h1>
    <a asp-action="Create" class="btn btn-success">
        <i class="fas fa-plus me-1"></i>New Customer
    </a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-auto flex-grow-1">
                <input type="text" name="searchString" class="form-control" placeholder="Search by name, phone, or email..." value="@ViewData["CurrentFilter"]" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Search</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive bg-white rounded shadow-sm">
    <table class="table table-hover mb-0">
        <thead class="bg-light">
            <tr>
                <th>Name</th>
                <th>Phone</th>
                <th>Email</th>
                <th>Points</th>
                <th>Visits</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <div class="fw-bold">@item.Name</div>
                        <small class="text-muted">Since @item.CreatedDate.ToString("MMM yyyy")</small>
                    </td>
                    <td>@(item.Phone ?? "-")</td>
                    <td>@(item.Email ?? "-")</td>
                    <td><span class="badge bg-info text-dark">@item.LoyaltyPoints pts</span></td>
                    <td>@item.VisitCount</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                            <i class="fas fa-edit"></i>
                        </a>
                        <button type="button" class="btn btn-sm btn-outline-danger" title="Delete" onclick="deleteCustomer(@item.Id, '@item.Name')">
                            <i class="fas fa-trash"></i>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="fas fa-user-slash fa-3x mb-3"></i>
            <p>No customers found.</p>
        </div>
    }
</div>

<!-- Delete Form -->
<form id="deleteForm" asp-action="Delete" method="post" style="display:none;">
    <input type="hidden" id="deleteId" name="id" />
</form>

@section Scripts {
    <script>
        function deleteCustomer(id, name) {
            Swal.fire({
                title: 'Delete Customer?',
                text: `Are you sure you want to delete "${name}"? This detail will remain in historical sales.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('deleteId').value = id;
                    document.getElementById('deleteForm').submit();
                }
            })
        }
    </script>
}
