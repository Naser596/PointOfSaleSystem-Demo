@model IEnumerable<WebApplication3.Models.Customer>

@{
    ViewData["Title"] = "Customers";
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-users me-3"></i>Customers</h1>
        <p>Customer records, loyalty points, visit history, and account statements.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus me-2"></i>New Customer
        </a>
    </div>
</div>

<form asp-action="Index" method="get" class="filter-shell">
    <div class="filter-stack">
        <label class="form-label fw-bold mb-0" for="customerSearch">Search customers</label>
        <div class="input-group">
            <span class="input-group-text"><i class="fas fa-search"></i></span>
            <input id="customerSearch" type="text" name="searchString" class="form-control" placeholder="Search by name, phone, or email..." value="@ViewData["CurrentFilter"]" />
        </div>
    </div>
    <div class="filter-actions">
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-search me-2"></i>Search
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-rotate-left me-2"></i>Reset
        </a>
    </div>
</form>

<div class="data-table-card">
    <div class="erp-surface-header">
        <div>
            <h2 class="erp-surface-title"><i class="fas fa-address-book me-2"></i>Customer List</h2>
            <p class="erp-surface-subtitle">Active and historical customers remain visible for sales history.</p>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>Email</th>
                    <th>Points</th>
                    <th>Visits</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="@(item.IsDeleted ? "table-light text-muted" : "")">
                        <td>
                            <div class="table-entity">
                                <div class="table-entity-media">
                                    <i class="fas fa-user"></i>
                                </div>
                                <div>
                                    <div class="table-entity-title">
                                        @item.Name
                                        @if (item.IsDeleted)
                                        {
                                            <span class="status-pill danger ms-2">Deleted</span>
                                        }
                                    </div>
                                    <div class="table-entity-meta">Since @item.CreatedDate.ToString("MMM yyyy")</div>
                                </div>
                            </div>
                        </td>
                        <td>@(item.Phone ?? "-")</td>
                        <td>@(item.Email ?? "-")</td>
                        <td><span class="status-pill info">@item.LoyaltyPoints pts</span></td>
                        <td>@item.VisitCount</td>
                        <td class="text-end">
                            <div class="table-actions">
                                <a asp-action="Statement" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success @(item.IsDeleted ? "disabled" : "")" title="Statement" aria-label="Open statement for @item.Name">
                                    <i class="fas fa-file-invoice-dollar"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary @(item.IsDeleted ? "disabled" : "")" title="Edit" aria-label="Edit @item.Name">
                                    <i class="fas fa-edit"></i>
                                </a>
                                @if (!item.IsDeleted)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-danger" title="Delete" aria-label="Delete @item.Name" onclick="deleteCustomer(@item.Id, '@item.Name')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (!Model.Any())
    {
        <div class="state-card">
            <i class="fas fa-user-slash fa-3x mb-3"></i>
            <p>No customers found.</p>
            <a asp-action="Create" class="btn btn-success">
                <i class="fas fa-plus me-2"></i>New Customer
            </a>
        </div>
    }
</div>

<form id="deleteForm" asp-action="Delete" method="post" style="display:none;">
    <input type="hidden" id="deleteId" name="id" />
</form>

@section Scripts {
    <script>
        function deleteCustomer(id, name) {
            Swal.fire({
                title: 'Delete Customer?',
                text: `Are you sure you want to delete "${name}"? This detail will remain in historical sales.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('deleteId').value = id;
                    document.getElementById('deleteForm').submit();
                }
            })
        }
    </script>
}
