    <script>
        // Immediate Theme Apply to prevent flash
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', savedTheme);
            const icon = savedTheme === 'dark' ? 'fa-sun' : 'fa-moon';
            window.addEventListener('DOMContentLoaded', () => {
                const btn = document.getElementById('themeToggle');
                if(btn) btn.innerHTML = `<i class="fas ${icon}"></i>`;
            });
        })();

        (function() {
            const pageAuthSession = '@pageAuthSession';

            function readCookie(name) {
                return document.cookie
                    .split('; ')
                    .find(row => row.startsWith(name + '='))
                    ?.split('=')[1] || '';
            }

            function redirectToLogin() {
                window.location.replace('/Account/Login');
            }

            function replaceStaleSessionPage() {
                if (!pageAuthSession) return;

                const activeSession = readCookie('pos_session');
                if (!activeSession || activeSession !== pageAuthSession) {
                    redirectToLogin();
                    return true;
                }

                if (localStorage.getItem('pos_logged_out') === pageAuthSession ||
                    sessionStorage.getItem('pos_logged_out') === pageAuthSession) {
                    redirectToLogin();
                    return true;
                }

                return false;
            }

            async function validateServerSession() {
                if (!pageAuthSession || replaceStaleSessionPage()) return;

                try {
                    const response = await fetch('/Account/SessionStatus', {
                        method: 'GET',
                        credentials: 'same-origin',
                        cache: 'no-store',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (!response.ok) {
                        redirectToLogin();
                        return;
                    }

                    const result = await response.json();
                    if (!result.authenticated || result.session !== pageAuthSession) {
                        redirectToLogin();
                    }
                } catch {
                    replaceStaleSessionPage();
                }
            }

            window.addEventListener('pageshow', validateServerSession);
            window.addEventListener('focus', validateServerSession);
            window.addEventListener('popstate', validateServerSession);
            window.addEventListener('storage', function(event) {
                if (event.key === 'pos_logged_out' && event.newValue === pageAuthSession) {
                    redirectToLogin();
                }
            });
            document.addEventListener('visibilitychange', function() {
                if (!document.hidden) {
                    validateServerSession();
                }
            });

            document.getElementById('logoutForm')?.addEventListener('submit', async function(event) {
                event.preventDefault();

                const form = event.currentTarget;
                const token = form.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                const logoutMarker = pageAuthSession || Date.now().toString();

                localStorage.setItem('pos_logged_out', logoutMarker);
                sessionStorage.setItem('pos_logged_out', logoutMarker);

                try {
                    const response = await fetch(form.action, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: new URLSearchParams({ __RequestVerificationToken: token }),
                        credentials: 'same-origin',
                        cache: 'no-store'
                    });

                    const result = await response.json();
                    window.location.replace(result.redirectUrl || '/Account/Login');
                } catch {
                    window.location.replace('/Account/Login');
                }
            });
        })();
    </script>

    @if (isAuthenticated)
