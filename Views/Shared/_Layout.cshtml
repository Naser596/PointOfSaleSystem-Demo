@inject WebApplication3.Services.ICompanySettingsService CompanySettingsService
@inject WebApplication3.Data.ApplicationDbContext LayoutDbContext
@using Microsoft.EntityFrameworkCore
@{
    var layoutCompany = await CompanySettingsService.GetSettingsAsync();
    Company? currentCompany = null;
    if (User.Identity?.IsAuthenticated == true && !User.IsInRole("SuperAdmin"))
    {
        var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (!string.IsNullOrEmpty(currentUserId))
        {
            currentCompany = await LayoutDbContext.Users
                .Where(u => u.Id == currentUserId)
                .Select(u => u.Company)
                .FirstOrDefaultAsync();
        }
    }
    var appTitle = currentCompany?.DisplayName ?? (string.IsNullOrWhiteSpace(layoutCompany.DisplayName) ? "MiniPOS" : layoutCompany.DisplayName);
    var appLogo = currentCompany?.LogoPath ?? layoutCompany.LogoPath;
    var brandColor = currentCompany?.PrimaryColor ?? layoutCompany.PrimaryColor;
    var currencyCode = currentCompany?.CurrencyCode ?? layoutCompany.CurrencyCode;
    var pageAuthSession = User.Identity?.IsAuthenticated == true
        ? Context.Request.Cookies["pos_session"]
        : null;
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var isSuperAdmin = User.IsInRole("SuperAdmin");
    var isAdmin = User.IsInRole("Admin");
    var canUseErp = User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("Accountant") || User.IsInRole("Warehouse") || User.IsInRole("HR");
    var routeController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    Func<string, string> activeNav = controller => string.Equals(routeController, controller, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;
}
