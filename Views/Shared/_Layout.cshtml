        <div id="onlineStatusBadge" class="online-status-badge">
            <i class="fas fa-wifi me-1"></i><span>Online</span>
        </div>
        <script>
            (function() {
                function updateOnlineStatus() {
                    const badge = document.getElementById('onlineStatusBadge');
                    if (!badge) return;

                    const online = navigator.onLine;
                    badge.classList.toggle('is-offline', !online);
                    badge.innerHTML = online
                        ? '<i class="fas fa-wifi me-1"></i><span>Online</span>'
                        : '<i class="fas fa-plug-circle-xmark me-1"></i><span>Offline</span>';
                }

                window.addEventListener('online', updateOnlineStatus);
                window.addEventListener('offline', updateOnlineStatus);
                document.addEventListener('DOMContentLoaded', updateOnlineStatus);
                updateOnlineStatus();
            })();
        </script>
    }

