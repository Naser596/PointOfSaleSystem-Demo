@model CompanySettingsViewModel
@{
    ViewData["Title"] = "Company Settings";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1><i class="fas fa-building me-3"></i>Company Settings</h1>
        <p>Save company details once and reuse them on invoices, receipts, and reports.</p>
    </div>
    <a asp-controller="SupplierInvoices" asp-action="Create" class="btn btn-primary">
        <i class="fas fa-file-invoice me-2"></i>Create Supplier Invoice
    </a>
</div>

<form asp-action="Index" enctype="multipart/form-data">
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-image me-2"></i>Brand</h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-3">
                        @if (!string.IsNullOrEmpty(Model.CurrentLogoPath))
                        {
                            <img src="@Model.CurrentLogoPath" alt="Company logo" class="img-fluid rounded border p-2" style="max-height: 140px;" />
                        }
                        else
                        {
                            <div class="border rounded p-4 text-muted">
                                <i class="fas fa-image fa-3x mb-2"></i>
                                <div>No logo uploaded</div>
                            </div>
                        }
                    </div>
                    <label asp-for="LogoFile" class="form-label"></label>
                    <input asp-for="LogoFile" class="form-control" type="file" accept=".jpg,.jpeg,.png,.webp" />
                    <span asp-validation-for="LogoFile" class="text-danger"></span>
                    <div class="form-text">Upload once. Change only when the company branding changes.</div>
                    <div class="mt-3">
                        <label asp-for="PrimaryColor" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="PrimaryColor" class="form-control" />
                            <input value="@Model.PrimaryColor" type="color" class="form-control form-control-color" onchange="document.getElementById('PrimaryColor').value=this.value" />
                        </div>
                        <span asp-validation-for="PrimaryColor" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-id-card me-2"></i>Company Details</h5>
                </div>
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="DisplayName" class="form-label"></label>
                            <input asp-for="DisplayName" class="form-control" />
                            <span asp-validation-for="DisplayName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LegalName" class="form-label"></label>
                            <input asp-for="LegalName" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="TaxNumber" class="form-label"></label>
                            <input asp-for="TaxNumber" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label"></label>
                            <input asp-for="Phone" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Country" class="form-label"></label>
                            <input asp-for="Country" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="City" class="form-label"></label>
                            <input asp-for="City" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Address" class="form-label"></label>
                            <input asp-for="Address" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CurrencyCode" class="form-label"></label>
                            <input asp-for="CurrencyCode" class="form-control text-uppercase" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DefaultTaxRate" class="form-label"></label>
                            <input asp-for="DefaultTaxRate" type="number" min="0" max="100" step="0.01" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mt-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-file-invoice-dollar me-2"></i>Invoice Defaults</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="InvoicePrefix" class="form-label"></label>
                            <input asp-for="InvoicePrefix" class="form-control text-uppercase" />
                            <span asp-validation-for="InvoicePrefix" class="text-danger"></span>
                        </div>
                        <div class="col-md-8">
                            <label asp-for="InvoiceFooterNote" class="form-label"></label>
                            <input asp-for="InvoiceFooterNote" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ReceiptFooterNote" class="form-label"></label>
                            <textarea asp-for="ReceiptFooterNote" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SupplierInvoiceFooterNote" class="form-label"></label>
                            <textarea asp-for="SupplierInvoiceFooterNote" class="form-control" rows="3"></textarea>
                        </div>
                    </div>

                    <div class="mt-4 d-flex justify-content-end gap-2">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-success px-4">
                            <i class="fas fa-save me-2"></i>Save Settings
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
