@model List<Company>
@{
    ViewData["Title"] = "Super Admin";
    var subscriptionAlerts = ViewBag.SubscriptionAlerts as List<CompanySubscriptionAlertViewModel> ?? new List<CompanySubscriptionAlertViewModel>();
    var autoDisabledCount = ViewBag.AutoDisabledCount as int? ?? 0;
    var companyHealth = ViewBag.CompanyHealth as List<CompanyHealthViewModel> ?? new List<CompanyHealthViewModel>();
    var healthByCompany = companyHealth.ToDictionary(h => h.CompanyId);
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-shield-alt me-3"></i>Platform Admin</h1>
        <p>Manage companies, subscriptions, branding, and company admins from one control surface.</p>
    </div>
    <div class="page-actions">
        <a asp-action="CreateCompany" class="btn btn-success">
            <i class="fas fa-plus me-2"></i>Create Company
        </a>
    </div>
</div>

@if (autoDisabledCount > 0)
{
    <div class="alert alert-danger shadow-sm">
        <i class="fas fa-ban me-2"></i>
        @autoDisabledCount company account(s) were auto-disabled because platform access expired after the grace period.
    </div>
}

@if (subscriptionAlerts.Any())
{
    <div class="erp-surface mb-4">
        <div class="erp-surface-header">
            <div>
                <h2 class="erp-surface-title"><i class="fas fa-triangle-exclamation me-2"></i>Platform Access Alerts</h2>
                <p class="erp-surface-subtitle">Companies close to expiry, already expired, or ready to disable.</p>
            </div>
            <a href="#companiesTable" class="btn btn-sm btn-outline-primary">View Companies</a>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Company</th>
                        <th>Access Until</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var alert in subscriptionAlerts.Take(8))
                    {
                        <tr>
                            <td><strong>@alert.CompanyName</strong></td>
                            <td>@(alert.AccessEndDate?.ToString("MMM dd, yyyy") ?? "-")</td>
                            <td>
                                @if (alert.ShouldDisable)
                                {
                                    <span class="status-pill danger">Grace ended</span>
                                }
                                else if (alert.IsInGracePeriod)
                                {
                                    <span class="status-pill warning">Grace period</span>
                                }
                                else if (alert.IsExpired)
                                {
                                    <span class="status-pill danger">Expired</span>
                                }
                                else
                                {
                                    <span class="status-pill info">@alert.DaysUntilExpiry day(s) left</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-action="EditCompany" asp-route-id="@alert.CompanyId" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-eye me-1"></i>View
                                    </a>
                                    <form asp-action="DisableCompany" asp-route-id="@alert.CompanyId" method="post" class="d-inline" onsubmit="return confirm('Disable this company?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="fas fa-ban me-1"></i>Disable
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<section class="dashboard-metric-grid" aria-label="Platform metrics">
    <div class="metric-card">
        <div class="metric-card-icon"><i class="fas fa-building"></i></div>
        <div>
            <div class="metric-card-value">@ViewBag.CompanyCount</div>
            <div class="metric-card-label">Companies</div>
            <div class="metric-card-note">Total platform tenants</div>
        </div>
    </div>
    <div class="metric-card">
        <div class="metric-card-icon"><i class="fas fa-check-circle"></i></div>
        <div>
            <div class="metric-card-value">@ViewBag.ActiveCompanyCount</div>
            <div class="metric-card-label">Active</div>
            <div class="metric-card-note">Currently enabled</div>
        </div>
    </div>
    <div class="metric-card">
        <div class="metric-card-icon"><i class="fas fa-users"></i></div>
        <div>
            <div class="metric-card-value">@ViewBag.UserCount</div>
            <div class="metric-card-label">Company users</div>
            <div class="metric-card-note">Users assigned to tenants</div>
        </div>
    </div>
    <div class="metric-card">
        <div class="metric-card-icon"><i class="fas fa-chart-line"></i></div>
        <div>
            <div class="metric-card-value">@ViewBag.PlatformSales</div>
            <div class="metric-card-label">Platform sales</div>
            <div class="metric-card-note">Sales across tenants</div>
        </div>
    </div>
    <div class="metric-card">
        <div class="metric-card-icon"><i class="fas fa-heart-pulse"></i></div>
        <div>
            <div class="metric-card-value">@ViewBag.AtRiskCompanyCount</div>
            <div class="metric-card-label">At Risk</div>
            <div class="metric-card-note">Health score below 55</div>
        </div>
    </div>
</section>

@if (companyHealth.Any())
{
    <div class="erp-surface mb-4">
        <div class="erp-surface-header">
            <div>
                <h2 class="erp-surface-title"><i class="fas fa-heart-pulse me-2"></i>Tenant Health</h2>
                <p class="erp-surface-subtitle">Operational signals from access, sales activity, sync issues, and audit activity.</p>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Company</th>
                        <th>Health</th>
                        <th class="text-end">Sales 30d</th>
                        <th class="text-end">Sync Issues</th>
                        <th>Last Sale</th>
                        <th>Last Activity</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var health in companyHealth.Take(8))
                    {
                        <tr>
                            <td><strong>@health.CompanyName</strong></td>
                            <td>
                                <span class="status-pill @health.HealthCssClass">@health.HealthStatus</span>
                                <div class="small text-muted">@health.HealthScore / 100</div>
                            </td>
                            <td class="text-end">@health.SalesLast30Days</td>
                            <td class="text-end @(health.FailedSyncCount > 0 ? "text-danger fw-bold" : "")">@health.FailedSyncCount</td>
                            <td>@(health.LastSaleDate?.ToString("MMM dd, yyyy") ?? "-")</td>
                            <td>@(health.LastAuditDate?.ToString("MMM dd, yyyy HH:mm") ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="data-table-card" id="companiesTable">
    <div class="erp-surface-header">
        <div>
            <h2 class="erp-surface-title"><i class="fas fa-building me-2"></i>Companies</h2>
            <p class="erp-surface-subtitle">Tenant status, access windows, users, and platform controls.</p>
        </div>
    </div>
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Company</th>
                        <th>Contact</th>
                        <th>Tax / VAT</th>
                        <th>Users</th>
                        <th>Health</th>
                        <th>Platform Access</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var company in Model)
                    {
                        <tr>
                            <td>
                                <div class="table-entity">
                                    <div class="table-entity-media">
                                        @if (!string.IsNullOrEmpty(company.LogoPath))
                                        {
                                            <img src="@company.LogoPath" alt="@company.DisplayName logo" />
                                        }
                                        else
                                        {
                                            <i class="fas fa-building"></i>
                                        }
                                    </div>
                                    <div>
                                        <div class="table-entity-title">@company.DisplayName</div>
                                        <div class="table-entity-meta">@company.LegalName</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div>@company.Email</div>
                                <div class="table-entity-meta">@company.Phone</div>
                            </td>
                            <td>@(company.TaxNumber ?? "-")</td>
                            <td>@company.Users.Count</td>
                            <td>
                                @if (healthByCompany.TryGetValue(company.Id, out var health))
                                {
                                    <span class="status-pill @health.HealthCssClass">@health.HealthStatus</span>
                                    <div class="small text-muted">@health.HealthScore / 100</div>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (company.PlatformAccessEndDate.HasValue)
                                {
                                    <div><strong>@company.PlatformAccessEndDate.Value.ToString("MMM dd, yyyy")</strong></div>
                                    @if (company.DaysUntilPlatformExpiry.HasValue)
                                    {
                                        if (company.ShouldAutoDisableForExpiredAccess)
                                        {
                                            <div class="text-danger fw-bold small">Grace ended</div>
                                        }
                                        else if (company.IsInPlatformGracePeriod)
                                        {
                                            <div class="text-warning fw-bold small">Grace period</div>
                                        }
                                        else if (company.DaysUntilPlatformExpiry.Value < 0)
                                        {
                                            <div class="text-danger fw-bold small">Expired</div>
                                        }
                                        else
                                        {
                                            <div class="text-muted small">@company.DaysUntilPlatformExpiry.Value day(s) left</div>
                                        }
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </td>
                            <td>
                                <span class="status-pill @(company.IsActive ? "success" : "")">
                                    @(company.IsActive ? "Active" : "Disabled")
                                </span>
                                @if (!string.IsNullOrWhiteSpace(company.PlatformDisabledReason))
                                {
                                    <div class="small text-muted mt-1">@company.PlatformDisabledReason</div>
                                }
                            </td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-action="EditCompany" asp-route-id="@company.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-pen me-1"></i>Edit
                                    </a>
                                    <a asp-action="ExportCompany" asp-route-id="@company.Id" class="btn btn-sm btn-outline-secondary">
                                        <i class="fas fa-file-export me-1"></i>Export
                                    </a>
                                    @if (company.IsActive)
                                    {
                                        <form asp-action="DisableCompany" asp-route-id="@company.Id" method="post" class="d-inline" onsubmit="return confirm('Disable this company?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="fas fa-ban me-1"></i>Disable
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="state-card">
            <i class="fas fa-building fa-3x mb-3"></i>
            <p>No companies created yet.</p>
            <a asp-action="CreateCompany" class="btn btn-success">
                <i class="fas fa-plus me-2"></i>Create Company
            </a>
        </div>
    }
</div>
