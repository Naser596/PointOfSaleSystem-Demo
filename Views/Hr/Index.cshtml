@model HrDashboardViewModel
@{
    ViewData["Title"] = "Employees";
    var employeeObligations = Model.EmployeeObligations
        .Where(o => o.EmployeeId.HasValue)
        .GroupBy(o => o.EmployeeId!.Value)
        .ToDictionary(g => g.Key, g => g.OrderBy(o => o.Status == "Paid").ThenBy(o => o.DueDate ?? DateTime.MaxValue).First());
}

<div class="page-header d-flex justify-content-between align-items-start gap-3">
    <div>
        <h1><i class="fas fa-users-gear me-3"></i>Employees</h1>
        <p>Create company employees, keep their details updated, and track salary obligations.</p>
    </div>
    <a href="/Obligations?type=Payroll" class="btn btn-outline-secondary"><i class="fas fa-hand-holding-dollar me-2"></i>Salary Obligations</a>
</div>

<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header"><i class="fas fa-user-plus me-2"></i>New Employee</div>
            <div class="card-body">
                <form asp-action="CreateEmployee" method="post" class="row g-3">
                    @Html.AntiForgeryToken()
                    <div class="col-md-4">
                        <label class="form-label">Full Name</label>
                        <input name="FullName" class="form-control" required />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Employee No.</label>
                        <input name="EmployeeNumber" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Personal No.</label>
                        <input name="PersonalNumber" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Job Title</label>
                        <input name="JobTitle" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Department</label>
                        <input name="Department" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Email</label>
                        <input name="Email" type="email" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Phone</label>
                        <input name="Phone" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Emergency Contact</label>
                        <input name="EmergencyContact" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Hire Date</label>
                        <input name="HireDate" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Monthly Salary</label>
                        <input name="MonthlySalary" type="number" step="0.01" min="0" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Due Day</label>
                        <input name="SalaryDueDay" type="number" min="1" max="31" value="5" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Address</label>
                        <input name="Address" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Notes</label>
                        <input name="Notes" class="form-control" />
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button type="submit" class="btn btn-success w-100"><i class="fas fa-plus me-2"></i>Add Employee</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header"><i class="fas fa-users me-2"></i>Employees</div>
    <div class="card-body p-0">
        @if (Model.Employees.Any())
        {
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Contact</th>
                            <th class="text-end">Salary</th>
                            <th>Salary Obligation</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var employee in Model.Employees)
                        {
                            employeeObligations.TryGetValue(employee.Id, out var obligation);
                            <tr>
                                <td>
                                    <strong>@employee.FullName</strong>
                                    <div class="small text-muted">@employee.EmployeeNumber @(!string.IsNullOrWhiteSpace(employee.JobTitle) ? $"| {employee.JobTitle}" : "")</div>
                                    @if (!string.IsNullOrWhiteSpace(employee.Department))
                                    {
                                        <div class="small text-muted">@employee.Department</div>
                                    }
                                </td>
                                <td>
                                    <div>@(employee.Phone ?? "-")</div>
                                    <div class="small text-muted">@employee.Email</div>
                                </td>
                                <td class="text-end">
                                    <strong>$@employee.MonthlySalary.ToString("N2")</strong>
                                    <div class="small text-muted">Due day @employee.SalaryDueDay</div>
                                </td>
                                <td>
                                    @if (obligation != null)
                                    {
                                        <span class="badge @(obligation.IsPaid ? "bg-success" : obligation.IsOverdue ? "bg-danger" : "bg-warning text-dark")">
                                            @(obligation.IsPaid ? "Paid" : obligation.IsOverdue ? "Overdue" : obligation.Status)
                                        </span>
                                        <div class="small text-muted">$@obligation.Amount.ToString("N2") due @(obligation.DueDate?.ToString("MMM dd, yyyy") ?? "-")</div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No open salary obligation</span>
                                    }
                                </td>
                                <td><span class="badge @(employee.IsActive ? "bg-success" : "bg-secondary")">@(employee.IsActive ? "Active" : "Inactive")</span></td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editEmployeeModal-@employee.Id">Edit</button>
                                    <form asp-action="ToggleEmployee" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@employee.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary">@(employee.IsActive ? "Deactivate" : "Activate")</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state"><i class="fas fa-users fa-3x mb-3"></i><p>No employees yet.</p></div>
        }
    </div>
</div>

@foreach (var employee in Model.Employees)
{
    <div class="modal fade" id="editEmployeeModal-@employee.Id" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content">
                <form asp-action="UpdateEmployee" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@employee.Id" />
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="fas fa-user-pen me-2"></i>Edit Employee</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Full Name</label>
                                <input name="FullName" value="@employee.FullName" class="form-control" required />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Employee No.</label>
                                <input name="EmployeeNumber" value="@employee.EmployeeNumber" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Personal No.</label>
                                <input name="PersonalNumber" value="@employee.PersonalNumber" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Job Title</label>
                                <input name="JobTitle" value="@employee.JobTitle" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Department</label>
                                <input name="Department" value="@employee.Department" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Email</label>
                                <input name="Email" value="@employee.Email" type="email" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Phone</label>
                                <input name="Phone" value="@employee.Phone" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Emergency Contact</label>
                                <input name="EmergencyContact" value="@employee.EmergencyContact" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Hire Date</label>
                                <input name="HireDate" type="date" value="@employee.HireDate.ToString("yyyy-MM-dd")" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Monthly Salary</label>
                                <input name="MonthlySalary" type="number" step="0.01" min="0" value="@employee.MonthlySalary.ToString("0.00")" class="form-control" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Due Day</label>
                                <input name="SalaryDueDay" type="number" min="1" max="31" value="@employee.SalaryDueDay" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Address</label>
                                <input name="Address" value="@employee.Address" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Notes</label>
                                <input name="Notes" value="@employee.Notes" class="form-control" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success"><i class="fas fa-save me-2"></i>Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
