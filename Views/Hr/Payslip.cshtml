@model PayrollRunLine
@{
    ViewData["Title"] = "Payslip";
}

<div class="page-header d-flex justify-content-between align-items-start gap-3">
    <div>
        <h1><i class="fas fa-file-lines me-3"></i>Payslip</h1>
        <p>@Model.Employee.FullName - @Model.PayrollRun.PeriodStart.ToString("MMM dd") to @Model.PayrollRun.PeriodEnd.ToString("MMM dd, yyyy")</p>
    </div>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-primary" onclick="window.print()">
            <i class="fas fa-print me-2"></i>Print
        </button>
        <a href="/Hr" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="document-shell">
    <div class="document-header">
        <div>
            <div class="document-title">Payslip</div>
            <div class="text-muted">@Model.PayrollRun.RunNumber</div>
        </div>
        <div class="text-end">
            <span class="badge @(Model.PayrollObligation?.IsPaid == true ? "bg-success" : "bg-warning text-dark")">
                @(Model.PayrollObligation?.IsPaid == true ? "Paid" : "Open")
            </span>
            <div class="small text-muted mt-2">Due @(Model.PayrollRun.DueDate?.ToString("MMM dd, yyyy") ?? "-")</div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="info-panel">
                <div class="info-label">Employee</div>
                <div class="info-value">@Model.Employee.FullName</div>
                <div class="text-muted">@Model.Employee.EmployeeNumber</div>
                <div class="text-muted">@Model.Employee.JobTitle</div>
                <div class="text-muted">@Model.Employee.Department</div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="info-panel">
                <div class="info-label">Payroll Period</div>
                <div class="info-value">@Model.PayrollRun.PeriodStart.ToString("MMM dd, yyyy") - @Model.PayrollRun.PeriodEnd.ToString("MMM dd, yyyy")</div>
                <div class="text-muted">Created @Model.PayrollRun.CreatedDate.ToString("MMM dd, yyyy HH:mm")</div>
                <div class="text-muted">Created by @(Model.PayrollRun.CreatedBy ?? "-")</div>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Description</th>
                    <th class="text-end">Amount</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Base Salary</td>
                    <td class="text-end">$@Model.BaseSalaryAmount.ToString("N2")</td>
                </tr>
                <tr>
                    <td>Bonus</td>
                    <td class="text-end">$@Model.BonusAmount.ToString("N2")</td>
                </tr>
                <tr>
                    <td>Other Deductions</td>
                    <td class="text-end text-danger">-$@Model.OtherDeductionsAmount.ToString("N2")</td>
                </tr>
                <tr>
                    <td>Taxes / Contributions</td>
                    <td class="text-end text-danger">-$@Model.TaxAmount.ToString("N2")</td>
                </tr>
            </tbody>
            <tfoot>
                <tr>
                    <th>Gross Pay</th>
                    <th class="text-end">$@Model.GrossAmount.ToString("N2")</th>
                </tr>
                <tr>
                    <th>Total Deductions</th>
                    <th class="text-end">$@Model.DeductionsAmount.ToString("N2")</th>
                </tr>
                <tr>
                    <th>Net Pay</th>
                    <th class="text-end">$@Model.NetAmount.ToString("N2")</th>
                </tr>
            </tfoot>
        </table>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Notes))
    {
        <div class="alert alert-light border mt-4 mb-0">
            <strong>Notes:</strong> @Model.Notes
        </div>
    }
</div>

@section Scripts {
    <style>
        @@media print {
            .navbar,
            .app-sidebar,
            .page-header .btn,
            footer,
            #onlineStatusBadge {
                display: none !important;
            }

            .app-main,
            .app-content {
                margin: 0 !important;
                padding: 0 !important;
            }

            .document-shell {
                box-shadow: none !important;
                border: 0 !important;
            }
        }
    </style>
}
