@model List<Product>
@inject WebApplication3.Services.ICategoryService CategoryService
@{
    ViewData["Title"] = "Products";
    var categories = await CategoryService.GetActiveCategoriesAsync();
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-box me-3"></i>Products</h1>
        <p>Manage inventory, pricing, tax, stock thresholds, and category filters.</p>
    </div>
    <div class="page-actions">
        <a href="/Products/Create" class="btn btn-success">
            <i class="fas fa-plus me-2"></i>Add Product
        </a>
    </div>
</div>

<div class="row g-4">
    <aside class="col-lg-3">
        <div class="category-filter-panel">
            <div class="erp-surface-header">
                <div>
                    <h2 class="erp-surface-title"><i class="fas fa-filter me-2"></i>Categories</h2>
                    <p class="erp-surface-subtitle">Filter the product catalog</p>
                </div>
            </div>
            <div class="list-group list-group-flush" id="categoryList">
                <a href="#" class="list-group-item list-group-item-action active d-flex justify-content-between align-items-center" data-category-id="">
                    <span><i class="fas fa-layer-group me-2"></i>All Categories</span>
                    <span class="badge bg-secondary rounded-pill">All</span>
                </a>
                @foreach (var category in categories)
                {
                    <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" data-category-id="@category.Id">
                        <span><i class="@(category.IconClass ?? "fas fa-folder") me-2"></i>@category.Name</span>
                    </a>
                }
            </div>
        </div>
    </aside>

    <section class="col-lg-9">
        <div class="filter-shell">
            <div class="filter-stack">
                <label class="form-label fw-bold mb-0" for="searchInput">Search products</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" id="searchInput" class="form-control" placeholder="Search by name, SKU, or description..." autocomplete="off">
                </div>
            </div>
            <div class="filter-actions">
                <a href="/Products" class="btn btn-outline-secondary">
                    <i class="fas fa-rotate-left me-2"></i>Reset
                </a>
            </div>
        </div>

        <div class="data-table-card">
            <div class="erp-surface-header">
                <div>
                    <h2 class="erp-surface-title"><i class="fas fa-table me-2"></i>Product Catalog</h2>
                    <p class="erp-surface-subtitle">Cost, price, margin, tax, and stock state</p>
                </div>
            </div>
            <div id="productTableContainer">
                <partial name="_ProductTable" model="Model" />
            </div>
        </div>
    </section>
</div>

<form id="deleteForm" method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function() {
    let currentCategoryId = '';
    let searchTimer;
    const container = document.getElementById('productTableContainer');

    const categoryLinks = document.querySelectorAll('#categoryList .list-group-item');
    categoryLinks.forEach(link => {
        link.addEventListener('click', function(e) {
            e.preventDefault();

            categoryLinks.forEach(l => l.classList.remove('active'));
            this.classList.add('active');

            currentCategoryId = this.dataset.categoryId;
            loadProducts();
        });
    });

    const searchInput = document.getElementById('searchInput');
    searchInput.addEventListener('input', function() {
        clearTimeout(searchTimer);
        searchTimer = setTimeout(loadProducts, 300);
    });

    function setLoading(isLoading) {
        container.style.opacity = isLoading ? '0.55' : '1';
        container.setAttribute('aria-busy', isLoading ? 'true' : 'false');
    }

    function loadProducts() {
        const searchTerm = searchInput.value;
        const url = `/Products/Filter?categoryId=${currentCategoryId}&searchTerm=${encodeURIComponent(searchTerm)}`;

        setLoading(true);

        fetch(url)
            .then(response => response.text())
            .then(html => {
                container.innerHTML = html;
                setLoading(false);
                rebindDeleteButtons();
            })
            .catch(error => {
                console.error('Error loading products:', error);
                setLoading(false);
                showToast('Could not load products. Please try again.', 'error');
            });
    }

    function rebindDeleteButtons() {
        document.querySelectorAll('.btn-delete').forEach(function(btn) {
            btn.addEventListener('click', function() {
                const id = this.dataset.id;
                const name = this.dataset.name;

                Swal.fire({
                    title: 'Delete Product?',
                    html: `Are you sure you want to delete <strong>${name}</strong>?<br><small class="text-muted">This action cannot be undone.</small>`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc3545',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: '<i class="fas fa-trash me-1"></i> Delete',
                    cancelButtonText: 'Cancel',
                    focusCancel: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        const form = document.getElementById('deleteForm');
                        form.action = '/Products/Delete/' + id;
                        form.submit();
                    }
                });
            });
        });
    }

    rebindDeleteButtons();
});
</script>
}
