@model List<Product>
@{
    ViewData["Title"] = "Products";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1><i class="fas fa-box me-3"></i>Products</h1>
        <p>Manage your product inventory</p>
    </div>
    <a href="/Products/Create" class="btn btn-success">
        <i class="fas fa-plus me-2"></i>Add Product
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Category</th>
                            <th>SKU</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model)
                        {
                            <tr class="@(product.IsLowStock ? "table-warning" : "")">
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="me-3" style="width: 65px; height: 65px; flex-shrink: 0;">
                                            @if (!string.IsNullOrEmpty(product.ImagePath))
                                            {
                                                <img src="@product.ImagePath" 
                                                     class="shadow-sm w-100 h-100" 
                                                     style="object-fit: cover; border: 2px solid #e9ecef; border-radius: 12px;" 
                                                     alt="@product.Name" />
                                            }
                                            else
                                            {
                                                <div class="bg-light w-100 h-100 d-flex align-items-center justify-content-center" style="border: 2px dashed #dee2e6; border-radius: 12px;">
                                                    <i class="fas fa-image text-muted"></i>
                                                </div>
                                            }
                                        </div>
                                        <div>
                                            <strong>@product.Name</strong>
                                            @if (product.IsLowStock)
                                            {
                                                <i class="fas fa-exclamation-triangle text-warning ms-1" title="Low Stock"></i>
                                            }
                                            <br/>
                                            <small class="text-muted">@(product.Description?.Length > 50 ? product.Description.Substring(0, 50) + "..." : product.Description)</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (product.Category != null)
                                    {
                                        <span class="badge bg-primary">
                                            <i class="@(product.Category.IconClass ?? "fas fa-folder") me-1"></i>
                                            @product.Category.Name
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td><code>@(product.SKU ?? "-")</code></td>
                                <td><span class="fw-bold text-success">$@product.Price.ToString("N2")</span></td>
                                <td>
                                    @if (product.Stock == 0)
                                    {
                                        <span class="badge bg-danger">Out of stock</span>
                                    }
                                    else if (product.IsLowStock)
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="fas fa-exclamation-circle me-1"></i>@product.Stock / @product.MinStock min
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">@product.Stock in stock</span>
                                    }
                                </td>
                                <td>
                                    <a href="/Products/Edit/@product.Id" class="btn btn-sm btn-outline-primary me-1" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="/Products/Details/@product.Id" class="btn btn-sm btn-outline-info me-1" title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-outline-danger btn-delete" 
                                            data-id="@product.Id" 
                                            data-name="@product.Name" 
                                            title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-box-open fa-3x mb-3"></i>
                <p>No products yet. Add your first product!</p>
                <a href="/Products/Create" class="btn btn-success">
                    <i class="fas fa-plus me-2"></i>Add Product
                </a>
            </div>
        }
    </div>
</div>

<!-- Hidden Delete Form -->
<form id="deleteForm" method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.btn-delete').forEach(function(btn) {
        btn.addEventListener('click', function() {
            const id = this.dataset.id;
            const name = this.dataset.name;
            
            Swal.fire({
                title: 'Delete Product?',
                html: `Are you sure you want to delete <strong>${name}</strong>?<br><small class="text-muted">This action cannot be undone.</small>`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: '<i class="fas fa-trash me-1"></i> Delete',
                cancelButtonText: 'Cancel',
                focusCancel: true
            }).then((result) => {
                if (result.isConfirmed) {
                    const form = document.getElementById('deleteForm');
                    form.action = '/Products/Delete/' + id;
                    form.submit();
                }
            });
        });
    });
});
</script>
}
