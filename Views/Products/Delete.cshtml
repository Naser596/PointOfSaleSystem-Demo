@model Product
@{
    ViewData["Title"] = "Delete Product";
}

<div class="page-header">
    <h1><i class="fas fa-trash me-3 text-danger"></i>Delete Product</h1>
    <p>Are you sure you want to delete this product?</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-danger">
            <div class="card-body">
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    This action cannot be undone!
                </div>
                <div class="text-center mb-4">
                    <div class="bg-danger bg-opacity-10 rounded-circle d-inline-flex p-4 mb-3">
                        <i class="fas fa-box fa-3x text-danger"></i>
                    </div>
                    <h3>@Model.Name</h3>
                    <p class="text-muted">@Model.Description</p>
                    <p class="h4 text-success">$@Model.Price.ToString("N2")</p>
                </div>
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-3 justify-content-center">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash me-2"></i>Delete Product
                        </button>
                        <a href="/Products" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
