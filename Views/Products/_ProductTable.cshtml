@model List<Product>

@if (Model != null && Model.Any())
{
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Category</th>
                    <th>SKU</th>
                    <th class="money-cell">Cost</th>
                    <th class="money-cell">Price</th>
                    <th class="money-cell">Margin</th>
                    <th class="text-center">Tax</th>
                    <th>Stock</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr class="@(product.IsLowStock ? "table-warning" : "")">
                        <td>
                            <div class="table-entity">
                                <div class="table-entity-media">
                                    @if (!string.IsNullOrEmpty(product.ImagePath))
                                    {
                                        <img src="@product.ImagePath" alt="@product.Name" loading="lazy" />
                                    }
                                    else
                                    {
                                        <i class="fas fa-image"></i>
                                    }
                                </div>
                                <div>
                                    <div class="table-entity-title">
                                        @product.Name
                                        @if (product.IsLowStock)
                                        {
                                            <i class="fas fa-exclamation-triangle text-warning ms-1" title="Low Stock"></i>
                                        }
                                    </div>
                                    <div class="table-entity-meta">@(product.Description?.Length > 64 ? product.Description.Substring(0, 64) + "..." : product.Description)</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            @if (product.Category != null)
                            {
                                <span class="status-pill info">
                                    <i class="@(product.Category.IconClass ?? "fas fa-folder")"></i>
                                    @product.Category.Name
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td><code>@(product.SKU ?? "-")</code></td>
                        <td class="money-cell">$@product.CostPrice.ToString("N2")</td>
                        <td class="money-cell"><strong class="text-success">$@product.Price.ToString("N2")</strong></td>
                        <td class="money-cell">
                            <span class="fw-semibold @(product.Price - product.CostPrice >= 0 ? "text-success" : "text-danger")">
                                $@((product.Price - product.CostPrice).ToString("N2"))
                            </span>
                        </td>
                        <td class="text-center">@product.TaxRate.ToString("N2")%</td>
                        <td>
                            @if (product.Stock == 0)
                            {
                                <span class="status-pill danger">Out of stock</span>
                            }
                            else if (product.IsLowStock)
                            {
                                <span class="status-pill warning">
                                    <i class="fas fa-exclamation-circle"></i>@product.Stock / @product.MinStock min
                                </span>
                            }
                            else
                            {
                                <span class="status-pill success">@product.Stock in stock</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="table-actions">
                                <a href="/Products/Edit/@product.Id" class="btn btn-sm btn-outline-primary" title="Edit product" aria-label="Edit @product.Name">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a href="/Products/Details/@product.Id" class="btn btn-sm btn-outline-info" title="View details" aria-label="View @product.Name details">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-delete"
                                        data-id="@product.Id"
                                        data-name="@product.Name"
                                        title="Delete product"
                                        aria-label="Delete @product.Name">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="state-card">
        <i class="fas fa-box-open fa-3x mb-3"></i>
        <p>No products found matching your criteria.</p>
        <a href="/Products/Create" class="btn btn-success">
            <i class="fas fa-plus me-2"></i>Add Product
        </a>
    </div>
}
