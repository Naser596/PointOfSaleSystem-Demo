@{
    ViewData["Title"] = "Dashboard";
    var lowStockProducts = ViewBag.LowStockProducts as List<Product> ?? new List<Product>();
}

<div class="page-header">
    <h1><i class="fas fa-chart-line me-3"></i>Dashboard</h1>
    <p> Your simple point of sale system</p>
</div>

<!-- Low Stock Alert -->
@if (User.IsInRole("Admin") && ViewBag.LowStockCount > 0)
{
    <div class="alert alert-warning alert-dismissible fade show shadow-sm mb-4" role="alert">
        <div class="d-flex align-items-center">
            <i class="fas fa-exclamation-triangle fa-2x me-3"></i>
            <div class="flex-grow-1">
                <h5 class="mb-1">Low Stock Alert!</h5>
                <p class="mb-0">@ViewBag.LowStockCount product(s) are running low on stock.</p>
            </div>
            <button type="button" class="btn btn-warning btn-sm" data-bs-toggle="collapse" data-bs-target="#lowStockList">
                <i class="fas fa-eye me-1"></i>View Details
            </button>
        </div>
        <div class="collapse mt-3" id="lowStockList">
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Category</th>
                            <th class="text-center">Current Stock</th>
                            <th class="text-center">Min Stock</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in lowStockProducts)
                        {
                            <tr>
                                <td><strong>@product.Name</strong></td>
                                <td>@(product.Category?.Name ?? "-")</td>
                                <td class="text-center">
                                    <span class="badge @(product.Stock == 0 ? "bg-danger" : "bg-warning")">
                                        @product.Stock
                                    </span>
                                </td>
                                <td class="text-center text-muted">@product.MinStock</td>
                                <td>
                                    <a href="/Products/Edit/@product.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-sync-alt me-1"></i>Restock
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Stats Row -->
<div class="row g-4 mb-4">
    <!-- Total Products (Unchanged) -->
    <div class="col-md-6 col-lg-3">
        <div class="stat-card primary">
            <i class="fas fa-box stat-icon"></i>
            <div class="stat-value">@ViewBag.TotalProducts</div>
            <div class="stat-label">Total Products</div>
        </div>
    </div>
    
    <!-- Today's Sales (New) -->
    <div class="col-md-6 col-lg-3">
        <div class="stat-card success">
            <i class="fas fa-receipt stat-icon"></i>
            <div class="stat-value">@ViewBag.TodaySales</div>
            <div class="stat-label">Today's Sales</div>
        </div>
    </div>

    <!-- Today's Revenue (Existing) -->
    <div class="col-md-6 col-lg-3">
        <div class="stat-card warning">
            <i class="fas fa-dollar-sign stat-icon"></i>
            <div class="stat-value">$@ViewBag.TodayRevenue?.ToString("N2")</div>
            <div class="stat-label">Today's Revenue</div>
        </div>
    </div>
    
    <!-- Low Stock Alert -->
    @if (User.IsInRole("Admin"))
    {
        <div class="col-md-6 col-lg-3">
            <div class="stat-card @(ViewBag.LowStockCount > 0 ? "danger" : "info")">
                <i class="fas fa-exclamation-triangle stat-icon"></i>
                <div class="stat-value">@ViewBag.LowStockCount</div>
                <div class="stat-label">Low Stock Items</div>
            </div>
        </div>
    }
</div>

@if (User.IsInRole("Admin"))
{
    <div class="row g-4 mb-5">
        <!-- All Sales History (New Label) -->
        <div class="col-md-6 col-lg-3">
            <div class="stat-card info">
                <i class="fas fa-chart-bar stat-icon"></i>
                <div class="stat-value">@ViewBag.AllSalesHistory</div>
                <div class="stat-label">All Sales History</div>
            </div>
        </div>

        <!-- All Revenue (New Label) -->
        <div class="col-md-6 col-lg-3">
            <div class="stat-card secondary">
                <i class="fas fa-coins stat-icon"></i>
                <div class="stat-value">$@ViewBag.AllRevenue?.ToString("N2")</div>
                <div class="stat-label">All Revenue</div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row g-4 mb-5">
        <!-- Sales Trend Chart -->
        <div class="col-lg-8">
            <div class="card h-100">
                <div class="card-header">
                    <i class="fas fa-chart-line me-2"></i>Sales Trend (Last 7 Days)
                </div>
                <div class="card-body">
                    <canvas id="salesChart" height="200"></canvas>
                </div>
            </div>
        </div>

        <!-- Top Selling Products -->
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header">
                    <i class="fas fa-trophy me-2"></i>Top Selling Products
                </div>
                <div class="card-body p-0">
                    @{
                        var topSellers = ViewBag.TopSellers as IEnumerable<dynamic>;
                    }
                    @if (topSellers != null && topSellers.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @{ int rank = 1; }
                            @foreach (var item in topSellers)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="badge bg-primary me-2">@(rank++)</span>
                                        <strong>@item.ProductName</strong>
                                    </div>
                                    <span class="badge bg-success rounded-pill">@item.TotalQty sold</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="fas fa-box-open fa-2x mb-2"></i>
                            <p class="mb-0">No sales data yet</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Quick Actions -->
<div class="row g-4 mb-5">
    <div class="col-md-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body text-center py-5">
                <div class="mb-4">
                    <i class="fas fa-shopping-cart fa-3x" style="color: var(--primary);"></i>
                </div>
                <h5 class="card-title mb-3">New Sale</h5>
                <p class="text-muted mb-4">Start a new sale transaction using the POS terminal</p>
                <a href="/POS" class="btn btn-primary">
                    <i class="fas fa-play me-2"></i>Open POS
                </a>
            </div>
        </div>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <div class="col-md-6 col-lg-3">
            <div class="card h-100">
                <div class="card-body text-center py-5">
                    <div class="mb-4">
                        <i class="fas fa-plus-circle fa-3x" style="color: var(--success);"></i>
                    </div>
                    <h5 class="card-title mb-3">Add Product</h5>
                    <p class="text-muted mb-4">Add new products to your inventory</p>
                    <a href="/Products/Create" class="btn btn-success">
                        <i class="fas fa-plus me-2"></i>Add Product
                    </a>
                </div>
            </div>
        </div>
    }
    <div class="col-md-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body text-center py-5">
                <div class="mb-4">
                    <i class="fas fa-history fa-3x" style="color: var(--info);"></i>
                </div>
                <h5 class="card-title mb-3">View Sales</h5>
                <p class="text-muted mb-4">View your sales history and details</p>
                <a href="/Sales" class="btn btn-info text-white">
                    <i class="fas fa-list me-2"></i>View Sales
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body text-center py-5">
                <div class="mb-4">
                    <i class="fas fa-file-excel fa-3x" style="color: #10b981;"></i>
                </div>
                <h5 class="card-title mb-3">Daily Report</h5>
                <p class="text-muted mb-4">Export today's sales to Excel</p>
                <a href="/Sales/ExportDailyReport" class="btn btn-success text-white">
                    <i class="fas fa-download me-2"></i>Download
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Recent Sales -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-clock me-2"></i>Recent Sales</span>
        <a href="/Sales" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="card-body p-0">
        @if (ViewBag.RecentSales != null && ((IEnumerable<Sale>)ViewBag.RecentSales).Any())
        {
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Sale #</th>
                        <th>Date</th>
                        <th>Cashier</th>
                        <th>Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sale in (IEnumerable<Sale>)ViewBag.RecentSales)
                    {
                        <tr>
                            <td><strong>@sale.SaleNumber</strong></td>
                            <td>@sale.SaleDate.ToString("MMM dd, yyyy HH:mm")</td>
                            <td>@(sale.CashierName ?? "-")</td>
                            <td><span class="text-success fw-bold">$@sale.TotalAmount.ToString("N2")</span></td>
                            <td><span class="badge bg-success">@sale.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-inbox fa-3x mb-3"></i>
                <p>No sales yet. Start by making your first sale!</p>
                <a href="/POS" class="btn btn-primary">Open POS Terminal</a>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const ctx = document.getElementById('salesChart');
        if (ctx) {
            const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartLabels ?? new List<string>()));
            const values = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartValues ?? new List<double>()));
            
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Revenue ($)',
                        data: values,
                        backgroundColor: 'rgba(59, 130, 246, 0.7)',
                        borderColor: 'rgba(59, 130, 246, 1)',
                        borderWidth: 2,
                        borderRadius: 8,
                        hoverBackgroundColor: 'rgba(59, 130, 246, 0.9)'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return '$' + value.toLocaleString();
                                }
                            }
                        }
                    }
                }
            });
        }
    });
</script>
}
