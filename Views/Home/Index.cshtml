@{
    ViewData["Title"] = "Dashboard";
    var lowStockProducts = ViewBag.LowStockProducts as List<Product> ?? new List<Product>();
    var dueObligations = ViewBag.DueObligations as List<PayrollObligation> ?? new List<PayrollObligation>();
    var recentSales = ViewBag.RecentSales as IEnumerable<Sale> ?? Enumerable.Empty<Sale>();
    var topSellers = ViewBag.TopSellers as IEnumerable<dynamic>;
    var userPerformance = ViewBag.UserPerformance as IEnumerable<dynamic>;
    var isAdmin = User.IsInRole("Admin");
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-chart-line me-3"></i>Dashboard</h1>
        <p>Sales, profit, stock alerts, and operator performance</p>
    </div>
    <div class="page-actions">
        <a href="/POS" class="btn btn-primary">
            <i class="fas fa-cash-register me-2"></i>Open POS
        </a>
        <a href="/Sales" class="btn btn-outline-secondary">
            <i class="fas fa-receipt me-2"></i>Sales
        </a>
        @if (isAdmin)
        {
            <a href="/Reports" class="btn btn-outline-secondary">
                <i class="fas fa-chart-line me-2"></i>Reports
            </a>
        }
    </div>
</div>

@if (isAdmin)
{
    <section class="business-command-center mb-4">
        <div>
            <div class="section-kicker">Business overview</div>
            <h2>Operational performance</h2>
            <p>Cash flow, profit, refunds, inventory pressure, and team output in one control surface.</p>
        </div>
        <div class="business-metrics">
            <div>
                <span>Net today</span>
                <strong>$@ViewBag.TodayNetRevenue?.ToString("N2")</strong>
            </div>
            <div>
                <span>Profit today</span>
                <strong>$@ViewBag.TodayProfit?.ToString("N2")</strong>
            </div>
            <div>
                <span>Month revenue</span>
                <strong>$@ViewBag.MonthRevenue?.ToString("N2")</strong>
            </div>
            <div>
                <span>Stock risk</span>
                <strong>@ViewBag.LowStockCount</strong>
            </div>
        </div>
        <div class="business-actions">
            <a href="/Finance" class="btn btn-primary"><i class="fas fa-chart-pie me-2"></i>Finance</a>
            <a href="/Products" class="btn btn-outline-secondary"><i class="fas fa-box me-2"></i>Inventory</a>
            <a href="/Obligations" class="btn btn-outline-secondary"><i class="fas fa-hand-holding-dollar me-2"></i>Obligations</a>
        </div>
    </section>
}

<div class="dashboard-alert-stack">
    @if (isAdmin && dueObligations.Any())
    {
        var hasOverdue = (ViewBag.OverdueObligationCount ?? 0) > 0;
        <div class="alert @(hasOverdue ? "alert-danger" : "alert-warning") alert-dismissible fade show shadow-sm mb-0" role="alert">
            <div class="d-flex align-items-center gap-3 flex-wrap">
                <i class="fas @(hasOverdue ? "fa-triangle-exclamation" : "fa-calendar-day") fa-2x"></i>
                <div class="flex-grow-1">
                    <h5 class="mb-1">Company obligations need attention</h5>
                    <p class="mb-0">
                        @ViewBag.DueObligationCount obligation(s) due now or within 7 days.
                        Total: <strong>$@ViewBag.DueObligationTotal?.ToString("N2")</strong>
                    </p>
                </div>
                <a href="/Obligations" class="btn @(hasOverdue ? "btn-danger" : "btn-warning") btn-sm">
                    <i class="fas fa-list me-1"></i>Review
                </a>
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-toggle="collapse" data-bs-target="#dueObligationList">
                    <i class="fas fa-eye me-1"></i>Details
                </button>
            </div>
            <div class="collapse mt-3" id="dueObligationList">
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Payee</th>
                                <th>Due Date</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var obligation in dueObligations)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">@obligation.ObligationType</span></td>
                                    <td><strong>@obligation.Description</strong></td>
                                    <td>@(obligation.PayeeName ?? "-")</td>
                                    <td>
                                        @obligation.DueDate?.ToString("MMM dd, yyyy")
                                        @if (obligation.IsOverdue)
                                        {
                                            <span class="badge bg-danger ms-2">Overdue</span>
                                        }
                                    </td>
                                    <td class="text-end fw-bold">$@obligation.Amount.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (isAdmin && ViewBag.LowStockCount > 0)
    {
        <div class="alert alert-warning alert-dismissible fade show shadow-sm mb-0" role="alert">
            <div class="d-flex align-items-center gap-3 flex-wrap">
                <i class="fas fa-exclamation-triangle fa-2x"></i>
                <div class="flex-grow-1">
                    <h5 class="mb-1">Low stock alert</h5>
                    <p class="mb-0">@ViewBag.LowStockCount product(s) are running low on stock.</p>
                </div>
                <button type="button" class="btn btn-warning btn-sm" data-bs-toggle="collapse" data-bs-target="#lowStockList">
                    <i class="fas fa-eye me-1"></i>View details
                </button>
            </div>
            <div class="collapse mt-3" id="lowStockList">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Category</th>
                                <th class="text-center">Current Stock</th>
                                <th class="text-center">Min Stock</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in lowStockProducts)
                            {
                                <tr>
                                    <td><strong>@product.Name</strong></td>
                                    <td>@(product.Category?.Name ?? "-")</td>
                                    <td class="text-center">
                                        <span class="badge @(product.Stock == 0 ? "bg-danger" : "bg-warning")">
                                            @product.Stock
                                        </span>
                                    </td>
                                    <td class="text-center text-muted">@product.MinStock</td>
                                    <td>
                                        <a href="/Products/Edit/@product.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-sync-alt me-1"></i>Restock
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
</div>

<section class="dashboard-metric-grid" aria-label="Primary dashboard metrics">
    <div class="metric-card">
        <div class="metric-card-icon"><i class="fas fa-box"></i></div>
        <div>
            <div class="metric-card-value">@ViewBag.TotalProducts</div>
            <div class="metric-card-label">Products</div>
            <div class="metric-card-note">Active catalog coverage</div>
        </div>
    </div>
    <div class="metric-card">
        <div class="metric-card-icon"><i class="fas fa-receipt"></i></div>
        <div>
            <div class="metric-card-value">@ViewBag.TodaySales</div>
            <div class="metric-card-label">Sales today</div>
            <div class="metric-card-note">Transactions processed</div>
        </div>
    </div>
    <div class="metric-card">
        <div class="metric-card-icon"><i class="fas fa-dollar-sign"></i></div>
        <div>
            <div class="metric-card-value">$@ViewBag.TodayRevenue?.ToString("N2")</div>
            <div class="metric-card-label">Gross revenue</div>
            <div class="metric-card-note">Today before adjustments</div>
        </div>
    </div>
    @if (isAdmin)
    {
        <div class="metric-card">
            <div class="metric-card-icon"><i class="fas fa-triangle-exclamation"></i></div>
            <div>
                <div class="metric-card-value">@ViewBag.LowStockCount</div>
                <div class="metric-card-label">Stock risk</div>
                <div class="metric-card-note">Low or out of stock items</div>
            </div>
        </div>
    }
</section>

@if (isAdmin)
{
    <section class="dashboard-secondary-grid mb-4" aria-label="Secondary dashboard metrics">
        <div class="metric-card">
            <div class="metric-card-icon"><i class="fas fa-clock-rotate-left"></i></div>
            <div>
                <div class="metric-card-value">@ViewBag.AllSalesHistory</div>
                <div class="metric-card-label">All sales</div>
            </div>
        </div>
        <div class="metric-card">
            <div class="metric-card-icon"><i class="fas fa-coins"></i></div>
            <div>
                <div class="metric-card-value">$@ViewBag.AllRevenue?.ToString("N2")</div>
                <div class="metric-card-label">All revenue</div>
            </div>
        </div>
        <div class="metric-card">
            <div class="metric-card-icon"><i class="fas fa-sack-dollar"></i></div>
            <div>
                <div class="metric-card-value">$@ViewBag.TodayProfit?.ToString("N2")</div>
                <div class="metric-card-label">Profit today</div>
            </div>
        </div>
        <div class="metric-card">
            <div class="metric-card-icon"><i class="fas fa-calendar-days"></i></div>
            <div>
                <div class="metric-card-value">$@ViewBag.MonthRevenue?.ToString("N2")</div>
                <div class="metric-card-label">Month revenue</div>
            </div>
        </div>
        <div class="metric-card">
            <div class="metric-card-icon"><i class="fas fa-ticket"></i></div>
            <div>
                <div class="metric-card-value">$@ViewBag.AverageTicket?.ToString("N2")</div>
                <div class="metric-card-label">Average ticket</div>
            </div>
        </div>
        <div class="metric-card">
            <div class="metric-card-icon"><i class="fas fa-rotate-left"></i></div>
            <div>
                <div class="metric-card-value">$@ViewBag.TodayRefunds?.ToString("N2")</div>
                <div class="metric-card-label">Refunds today</div>
            </div>
        </div>
    </section>

    <section class="dashboard-workbench">
        <div class="dashboard-section">
            <div class="dashboard-section-header">
                <h2 class="dashboard-section-title"><i class="fas fa-chart-line me-2"></i>Sales Trend</h2>
                <span class="text-muted small">Last 7 days</span>
            </div>
            <div class="dashboard-section-body">
                <div class="chart-frame">
                    <canvas id="salesChart"></canvas>
                </div>
            </div>
        </div>

        <div class="dashboard-section">
            <div class="dashboard-section-header">
                <h2 class="dashboard-section-title"><i class="fas fa-trophy me-2"></i>Top Selling Products</h2>
                <a href="/Reports" class="btn btn-sm btn-outline-primary">Reports</a>
            </div>
            <div>
                @if (topSellers != null && topSellers.Any())
                {
                    <ul class="list-group list-group-flush">
                        @{ var rank = 1; }
                        @foreach (var item in topSellers)
                        {
                            <li class="list-group-item d-flex align-items-center p-3 border-0 border-bottom">
                                <div class="me-3 position-relative">
                                    @if (!string.IsNullOrEmpty(item.ImagePath))
                                    {
                                        <img src="@item.ImagePath" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover;" alt="@item.ProductName">
                                    }
                                    else
                                    {
                                        <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                            <i class="fas fa-cube text-muted"></i>
                                        </div>
                                    }
                                    <span class="position-absolute top-0 start-0 translate-middle badge rounded-pill bg-primary" style="font-size: 0.7rem;">
                                        @(rank++)
                                    </span>
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="mb-0 fw-bold">@item.ProductName</h6>
                                    <small class="text-muted">Revenue: $@item.TotalRevenue.ToString("N2")</small>
                                </div>
                                <span class="badge bg-success rounded-pill px-3">@item.TotalQty sold</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="state-card">
                        <i class="fas fa-box-open fa-2x mb-2"></i>
                        <p class="mb-0">No sales data yet.</p>
                    </div>
                }
            </div>
        </div>
    </section>

    <section class="dashboard-split">
        <div class="dashboard-section">
            <div class="dashboard-section-header">
                <h2 class="dashboard-section-title"><i class="fas fa-credit-card me-2"></i>Payment Split</h2>
                <span class="text-muted small">This month</span>
            </div>
            <div class="dashboard-section-body">
                <div class="chart-frame">
                    <canvas id="paymentChart"></canvas>
                </div>
            </div>
        </div>
        <div class="dashboard-section">
            <div class="dashboard-section-header">
                <h2 class="dashboard-section-title"><i class="fas fa-users me-2"></i>User Progress</h2>
                <a href="/Finance" class="btn btn-sm btn-outline-primary">Finance</a>
            </div>
            @if (userPerformance != null && userPerformance.Any())
            {
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th class="text-center">Sales</th>
                                <th class="text-end">Revenue</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in userPerformance)
                            {
                                <tr>
                                    <td><strong>@user.Cashier</strong></td>
                                    <td class="text-center">@user.Sales</td>
                                    <td class="text-end fw-bold">$@user.Revenue.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="state-card">
                    <i class="fas fa-user-clock fa-2x mb-2"></i>
                    <p class="mb-0">No user sales this month.</p>
                </div>
            }
        </div>
    </section>
}

<section class="dashboard-action-grid mb-4" aria-label="Quick actions">
    <a href="/POS" class="action-card">
        <i class="fas fa-cash-register"></i>
        <span>
            <strong>New sale</strong>
            <span>Open the POS terminal</span>
        </span>
    </a>
    @if (isAdmin)
    {
        <a href="/Products/Create" class="action-card">
            <i class="fas fa-plus"></i>
            <span>
                <strong>Add product</strong>
                <span>Create inventory item</span>
            </span>
        </a>
    }
    <a href="/Sales" class="action-card">
        <i class="fas fa-history"></i>
        <span>
            <strong>View sales</strong>
            <span>Review sales history</span>
        </span>
    </a>
    <a href="/Sales/ExportDailyReport" class="action-card">
        <i class="fas fa-file-excel"></i>
        <span>
            <strong>Daily report</strong>
            <span>Export today's sales</span>
        </span>
    </a>
</section>

<section class="dashboard-section">
    <div class="dashboard-section-header">
        <h2 class="dashboard-section-title"><i class="fas fa-clock me-2"></i>Recent Sales</h2>
        <a href="/Sales" class="btn btn-sm btn-outline-primary">View all</a>
    </div>
    @if (recentSales.Any())
    {
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Sale #</th>
                        <th>Date</th>
                        <th>Cashier</th>
                        <th class="text-end">Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sale in recentSales)
                    {
                        <tr>
                            <td><strong>@sale.SaleNumber</strong></td>
                            <td>@sale.SaleDate.ToString("MMM dd, yyyy HH:mm")</td>
                            <td>@(sale.CashierName ?? "-")</td>
                            <td class="text-end"><span class="text-success fw-bold">$@sale.TotalAmount.ToString("N2")</span></td>
                            <td><span class="badge bg-success">@sale.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="state-card">
            <i class="fas fa-inbox fa-3x mb-3"></i>
            <p>No sales yet. Start by making your first sale.</p>
            <a href="/POS" class="btn btn-primary">Open POS Terminal</a>
        </div>
    }
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ctx = document.getElementById('salesChart');
            if (ctx) {
                const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartLabels ?? new List<string>()));
                const values = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartValues ?? new List<double>()));
                const gridColor = getComputedStyle(document.documentElement).getPropertyValue('--chart-grid').trim() || 'rgba(148, 163, 184, 0.24)';
                const textColor = getComputedStyle(document.documentElement).getPropertyValue('--chart-text').trim() || '#334155';

                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Revenue ($)',
                            data: values,
                            backgroundColor: 'rgba(59, 130, 246, 0.7)',
                            borderColor: 'rgba(59, 130, 246, 1)',
                            borderWidth: 2,
                            borderRadius: 8,
                            hoverBackgroundColor: 'rgba(59, 130, 246, 0.9)'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: gridColor },
                                ticks: {
                                    color: textColor,
                                    callback: function (value) {
                                        return '$' + value.toLocaleString();
                                    }
                                }
                            },
                            x: {
                                grid: { display: false },
                                ticks: {
                                    color: textColor
                                }
                            }
                        }
                    }
                });
            }

            const paymentCtx = document.getElementById('paymentChart');
            if (paymentCtx) {
                const paymentLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.PaymentLabels ?? new List<string>()));
                const paymentValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.PaymentValues ?? new List<double>()));

                new Chart(paymentCtx, {
                    type: 'doughnut',
                    data: {
                        labels: paymentLabels,
                        datasets: [{
                            data: paymentValues,
                            backgroundColor: ['#2563eb', '#10b981', '#f59e0b', '#ef4444']
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    color: getComputedStyle(document.documentElement).getPropertyValue('--chart-text').trim() || '#334155'
                                }
                            }
                        }
                    }
                });
            }
        });
    </script>
}
