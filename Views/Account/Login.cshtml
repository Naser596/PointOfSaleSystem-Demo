@model WebApplication3.Models.LoginViewModel

@{
    ViewData["Title"] = "Log in";
}

<div class="row justify-content-center">
    <div class="col-md-4">
        <div class="card shadow-sm mt-5">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <h2 class="h4">Welcome Back</h2>
                    <p class="text-muted">Please sign in to continue</p>
                </div>

                <form id="loginForm" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post" autocomplete="off">
                    <div id="loginError" asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" placeholder="Password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input class="form-check-input" asp-for="RememberMe" />
                        <label class="form-check-label" asp-for="RememberMe">
                            @Html.DisplayNameFor(m => m.RememberMe)
                        </label>
                    </div>

                    <div class="d-grid gap-2">
                        <button id="loginSubmit" type="submit" class="btn btn-primary">Log in</button>
                    </div>
                </form>
            </div>
            <div class="card-footer text-center py-3">
                <small class="demo-credentials">Demo: admin@minipos.com / Admin123!</small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function() {
            const hasLogoutMarker = !!(localStorage.getItem('pos_logged_out') || sessionStorage.getItem('pos_logged_out'));
            if (!hasLogoutMarker) return;

            if (!sessionStorage.getItem('pos_logout_history_guarded')) {
                history.replaceState({ posLoginGuard: true }, '', '/Account/Login');
                history.pushState({ posLoginGuard: true }, '', '/Account/Login');
                sessionStorage.setItem('pos_logout_history_guarded', '1');
            }

            window.addEventListener('popstate', function() {
                if (localStorage.getItem('pos_logged_out') || sessionStorage.getItem('pos_logged_out')) {
                    history.pushState({ posLoginGuard: true }, '', '/Account/Login');
                }
            });
        })();

        window.addEventListener('pageshow', function(event) {
            if (event.persisted) {
                window.location.reload();
            }
        });

        document.getElementById('loginForm')?.addEventListener('submit', async function(event) {
            event.preventDefault();

            const form = event.currentTarget;
            const button = document.getElementById('loginSubmit');
            const errorBox = document.getElementById('loginError');

            if (errorBox) errorBox.textContent = '';
            if (button) {
                button.disabled = true;
                button.textContent = 'Signing in...';
            }

            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    body: new FormData(form),
                    credentials: 'same-origin',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                const result = await response.json();
                if (result.success) {
                    localStorage.removeItem('pos_logged_out');
                    sessionStorage.removeItem('pos_logged_out');
                    sessionStorage.removeItem('pos_logout_history_guarded');
                    window.location.replace(result.redirectUrl || '/');
                    return;
                }

                if (errorBox) errorBox.textContent = result.message || 'Invalid login attempt.';
            } catch {
                if (errorBox) errorBox.textContent = 'Login could not be completed. Please try again.';
            } finally {
                if (button) {
                    button.disabled = false;
                    button.textContent = 'Log in';
                }
            }
        });
    </script>
}
