@model Category
@{
    ViewData["Title"] = "Delete Category";
}

<div class="page-header">
    <h1><i class="fas fa-trash-alt me-3 text-danger"></i>Delete Category</h1>
    <p>Are you sure you want to delete this category?</p>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <i class="fas fa-exclamation-triangle me-2"></i>Confirm Deletion
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center me-3" style="width: 60px; height: 60px;">
                            <i class="@(Model.IconClass ?? "fas fa-folder") text-white fa-2x"></i>
                        </div>
                        <div>
                            <h4 class="mb-1">@Model.Name</h4>
                            <p class="text-muted mb-0">@(Model.Description ?? "No description")</p>
                        </div>
                    </div>
                    
                    @if (Model.Products.Any())
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-warning me-2"></i>
                            This category has <strong>@Model.Products.Count product(s)</strong>. 
                            Products will be uncategorized after deletion.
                        </div>
                    }
                </div>
                
                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash me-2"></i>Yes, Delete
                        </button>
                        <a href="/Categories" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
